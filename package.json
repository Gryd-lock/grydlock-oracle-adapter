{
  "name": "grydlock-oracle-adapter",
  "version": "0.1.0",
  "description": "Read-client that fetches a 0-100 risk score for a Stellar address or asset from an on-chain risk oracle.",
  "license": "MIT",
  "private": true,
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "stellar",
    "soroban",
    "risk-oracle",
    "gryd-lock"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "size": "node scripts/bundle-size.mjs",
    "docs": "typedoc",
    "docs:check": "typedoc --emit none",
    "prepare": "husky",
    "sbom": "bash scripts/sbom.sh",
    "license-check": "bash scripts/license-check.sh"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@cyclonedx/cyclonedx-npm": "^6.0.0",
    "@eslint/js": "^10.0.1",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/node": "^26.1.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.6.0",
    "husky": "^9.1.7",
    "license-checker-rseidelsohn": "^4.4.2",
    "prettier": "^3.9.4",
    "typedoc": "^0.28.20",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@stellar/stellar-sdk": "^16.0.1"
  },
  "overrides": {
    "axios": "^1.18.1"
  }
}
