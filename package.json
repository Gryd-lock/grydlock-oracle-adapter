{
  "name": "grydlock-oracle-adapter",
  "version": "0.1.0",
  "description": "Read-client that fetches a 0-100 risk score for a Stellar address or asset from an on-chain risk oracle.",
  "license": "UNLICENSED",
  "private": true,
  "keywords": [
    "stellar",
    "soroban",
    "risk-oracle",
    "gryd-lock"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.0",
    "eslint": "^10.6.0",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10"
  }
}
